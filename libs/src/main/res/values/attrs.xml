<?xml version="1.0" encoding="utf-8"?>
<resources>

    <declare-styleable name="ShapeContainer">
        <!-- Radius -->
        <attr name="cornerRadius" format="dimension" />
        <attr name="cornerDisableRadius" format="dimension" />
        <attr name="topLeftRadius" format="dimension" />
        <attr name="topLeftDisableRadius" format="dimension" />
        <attr name="topRightRadius" format="dimension" />
        <attr name="topRightDisableRadius" format="dimension" />
        <attr name="bottomLeftRadius" format="dimension" />
        <attr name="bottomLeftDisableRadius" format="dimension" />
        <attr name="bottomRightRadius" format="dimension" />
        <attr name="bottomRightDisableRadius" format="dimension" />

        <!-- Solid -->
        <attr name="solidColor" format="color" />
        <attr name="solidDisabledColor" format="color" />

        <!-- Stroke -->
        <attr name="strokeWidth" format="dimension" />
        <attr name="strokeDisabledWidth" format="dimension" />
        <attr name="strokeDashWidth" format="dimension" />
        <attr name="strokeDisabledDashWidth" format="dimension" />
        <attr name="strokeDashGap" format="dimension" />
        <attr name="strokeDisabledDashGap" format="dimension" />
        <attr name="strokeColor" format="color" />
        <attr name="strokeDisabledColor" format="color" />

        <!-- Ripple -->
        <attr name="rippleColor" format="color" />

        <!-- Enabled -->
        <attr name="enabled" format="boolean" />

        <!-- Clip -->
        <attr name="useClip" format="boolean" />

    </declare-styleable>

</resources>