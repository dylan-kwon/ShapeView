<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="20dp"
        tools:context=".MainActivity">

        <dylan.kwon.shapeview.component.ShapeImageView
            android:id="@+id/image_container"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:scaleType="centerCrop"
            android:src="@drawable/img"
            app:cornerRadius="20dp"
            app:layout_constraintTop_toTopOf="parent"
            app:useClip="true" />

        <dylan.kwon.shapeview.component.ShapeContainer
            android:id="@+id/first"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_marginTop="20dp"
            app:cornerRadius="20dp"
            app:layout_constraintEnd_toStartOf="@id/second"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/image_container"
            app:strokeColor="@color/blue"
            app:strokeWidth="5dp" />

        <dylan.kwon.shapeview.component.ShapeToggleButton
            android:id="@+id/second"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_marginStart="20dp"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:textColor="@color/black"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="8dp"
            app:layout_constraintEnd_toStartOf="@id/third"
            app:layout_constraintStart_toEndOf="@id/first"
            app:layout_constraintTop_toTopOf="@id/first"
            app:strokeColor="@{@color/red}"
            app:strokeDashGap="5dp"
            app:strokeDashWidth="5dp"
            app:strokeWidth="5dp"
            app:useClip="true"
            tools:solidColor="@color/white"
            tools:strokeColor="@color/red"
            tools:text="Text" />

        <dylan.kwon.shapeview.component.ShapeImageButton
            android:id="@+id/third"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_marginStart="20dp"
            android:clickable="true"
            android:focusable="true"
            android:scaleType="centerInside"
            android:src="@drawable/ic_baseline_done_outline_24"
            app:cornerRadius="100dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/second"
            app:layout_constraintTop_toTopOf="@id/first"
            app:solidColor="@color/yellow"
            app:strokeColor="@color/black"
            app:strokeDashGap="5dp"
            app:strokeDashWidth="5dp"
            app:strokeWidth="5dp"
            app:useClip="true" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>